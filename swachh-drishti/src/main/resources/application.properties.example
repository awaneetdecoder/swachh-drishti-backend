spring.application.name=swachh-drishti
# ── Server ────────────────────────────────────────────────
server.port=8080

# ── MySQL Database ─────────────────────────────────────────
spring.datasource.url=jdbc:mysql://localhost:3306/swachhdrishti?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=YOUR_MYSQL_USERNAME
spring.datasource.password=YOUR_MYSQL_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ── JPA / Hibernate ────────────────────────────────────────
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# ── JWT ────────────────────────────────────────────────────
# Generate your secret: any random string, minimum 64 characters
jwt.secret=YOUR_64_CHARACTER_SECRET_KEY_REPLACE_THIS_WITH_SOMETHING_LONG
jwt.expirationMs=86400000

# ── File Upload ────────────────────────────────────────────
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
app.upload.dir=uploads/

# ── Google Cloud Vision API ────────────────────────────────
google.vision.api.key=YOUR_GOOGLE_VISION_API_KEY

# ── CORS ───────────────────────────────────────────────────
app.cors.allowed-origins=http://localhost:3000
